# ===== SERVER =====
PORT=3000
NODE_ENV=development

# ===== DATABASE =====
# Render PostgreSQL (Neon retired April 2026, cf. feedback_no_neon).
DATABASE_URL=postgresql://user:password@dpg-xxx.region-postgres.render.com/db_name

# ===== AUTH =====
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=24h
MAGIC_LINK_BASE_URL=http://localhost:3000/auth/verify

# ===== TWILIO (SMS + Call filter) =====
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WEBHOOK_SECRET=your_webhook_secret

# ===== EMAIL (Brevo / Sendinblue) =====
BREVO_API_KEY=xkeysib-xxxxx
BREVO_SENDER_EMAIL=noreply@genda.be
BREVO_SENDER_NAME=Genda
# Webhook signature (obligatoire pour /api/webhooks/brevo — cf. brevo.js L30)
BREVO_WEBHOOK_SECRET=change-me-random-long-string

# ===== GOOGLE (Calendar sync + Client OAuth) =====
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# ===== APPLE SIGN IN (Client OAuth) =====
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ===== FACEBOOK LOGIN (Client OAuth) =====
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ===== OUTLOOK / MICROSOFT 365 SYNC =====
OUTLOOK_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OUTLOOK_CLIENT_SECRET=xxxxx

# ===== CRON =====
CRON_SECRET=change-me-random-cron-key

# ===== SENTRY (error tracking, optional) =====
# Si renseigné, active Sentry.setupExpressErrorHandler + captureException crons.
SENTRY_DSN=

# ===== STRIPE =====
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM=price_xxxxxxxxxxxxxxxxxxxx

# ===== APP URLs =====
APP_BASE_URL=http://localhost:3000
BOOKING_BASE_URL=http://localhost:3000
BASE_URL=http://localhost:3000

# ===== UPLOADS =====
# Where branding/practitioner/gallery/realisation/quote photos are written.
# Default (unset): public/uploads — EPHEMERAL on Render (lost on each deploy).
# Production on Render: mount a Disk under /var/data/uploads and set:
#   UPLOADS_DIR=/var/data/uploads
# The /uploads/* static route reads from this path automatically.
UPLOADS_DIR=

# ===== STRIPE CONNECT — PLATFORM FEE (optional) =====
# If set, Genda takes a cut of each Stripe deposit / gift-card / pass payment
# via application_fee_amount on the Connect transfer. Default (unset = 0) keeps
# the historical behavior where the merchant receives 100% and Genda absorbs
# Stripe processing fees.
#   STRIPE_APP_FEE_PCT=1.5            # percent of gross amount
#   STRIPE_APP_FEE_FIXED_CENTS=25     # fixed cents on top
STRIPE_APP_FEE_PCT=
STRIPE_APP_FEE_FIXED_CENTS=
