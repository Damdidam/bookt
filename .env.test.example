# Genda E2E tests — copy to .env.test and fill in
# NEVER commit .env.test (gitignored)
#
# RULE feedback_e2e_server_local.md: tests MUST run against a LOCAL server, never prod.
# Start the server first with `npm run dev` (uses localhost:3000) with SKIP_* env vars,
# then run `npm run test:e2e` in another terminal.

NODE_ENV=test

# Local PostgreSQL (recommended). Do NOT point at prod Render.
# Create a local DB then run: psql "$DATABASE_URL" -f schema.sql -f schema-v2-migration.sql ...
DATABASE_URL=postgresql://localhost:5432/bookt_test

# App URL (must be the local dev server)
APP_BASE_URL=http://localhost:3000

# Stripe TEST mode keys (never live keys for E2E)
STRIPE_SECRET_KEY=sk_test_XXX
STRIPE_SECRET_KEY_TEST=sk_test_XXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXX
STRIPE_WEBHOOK_SECRET=whsec_test_XXX
STRIPE_CONNECT_TEST_ACCOUNT=acct_test_XXX

# JWT — a 32+ char random string for tests (don't reuse prod secret)
JWT_SECRET=e2e-jwt-secret-change-me-32chars-minimum

# Brevo webhook secret — required for webhook security tests
BREVO_WEBHOOK_SECRET=test-brevo-secret

# Calendar token key — 32 bytes base64 for AES-GCM (required for sync tests)
# Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CALENDAR_TOKEN_KEY=

# Mock externals — required so tests never hit Brevo / Twilio APIs
SKIP_EMAIL=1
SKIP_SMS=1

# Test business ID (matches ids.js TEST_IDS.BUSINESS)
TEST_BUSINESS_ID=00000000-0000-4000-8000-000000000001
