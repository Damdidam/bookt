{
  "name": "genda",
  "version": "3.6.0",
  "description": "Genda — Votre cabinet en ligne en 10 minutes. SaaS multi-tenant pour professionnels libéraux (BE).",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "dev:client": "vite --config vite.config.js",
    "build": "vite build --config vite.config.js",
    "build:client": "vite build --config vite.config.js",
    "preview:client": "vite preview --config vite.config.js",
    "db:init": "node src/utils/db-init.js",
    "stripe:setup": "node scripts/stripe-setup.js",
    "test": "node tests/sanity.js",
    "test:slots": "node tests/sanity.js --section slots",
    "test:booking": "node tests/sanity.js --section booking",
    "test:staff": "node tests/sanity.js --section staff",
    "test:lifecycle": "node tests/sanity.js --section lifecycle",
    "test:deposit": "node tests/sanity.js --section deposit",
    "test:calendar": "node tests/sanity.js --section calendar",
    "test:edge": "node tests/sanity.js --section edge",
    "test:verbose": "node tests/sanity.js --verbose"
  },
  "dependencies": {
    "@fullcalendar/core": "~6.1.20",
    "@fullcalendar/daygrid": "~6.1.20",
    "@fullcalendar/interaction": "~6.1.20",
    "@fullcalendar/resource": "~6.1.20",
    "@fullcalendar/resource-timegrid": "~6.1.20",
    "@fullcalendar/resource-timeline": "~6.1.20",
    "@fullcalendar/timegrid": "~6.1.20",
    "@sentry/node": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.14.0",
    "pg": "^8.12.0",
    "stripe": "^14.0.0",
    "twilio": "^4.23.0",
    "uuid": "^9.0.0",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true
}
